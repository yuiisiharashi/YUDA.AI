<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>YUDA.AI</title>

<link rel="stylesheet" href="style.css">
</head>

<body>

<div class="sidebar">

    <div class="logo">
        🤖 YUDA.AI
    </div>

    <button id="newChat">
        + Chat Baru
    </button>

    <div class="history">

        <div class="chat-item active">
            💬 Percakapan Baru
        </div>

    </div>

</div>

<div class="main">

    <div class="header">
        <h2>YUDA.AI</h2>
        <span>AI Assistant</span>
    </div>

    <div id="chatBox" class="chat-box">

        <div class="ai message">
            Halo 👋<br>
            Saya <b>YUDA.AI</b>.<br><br>

            Silakan tanyakan apa saja.
        </div>

    </div>

    <div class="input-area">

        <textarea
            id="userInput"
            placeholder="Ketik pesan..."
        ></textarea>

        <button id="sendBtn">
            ➤
        </button>

    </div>

</div>

<script src="script.js"></script>

</body>
</html>
